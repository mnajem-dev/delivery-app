DATABASE_URL=postgresql://postgres:postgres@localhost:5432/delivery_app
JWT_SECRET=change-me-in-production
JWT_EXPIRES_IN=7d

# Object storage (MinIO via docker-compose, or any S3-compatible provider)
STORAGE_ENDPOINT=http://localhost:9000
STORAGE_REGION=us-east-1
STORAGE_ACCESS_KEY=minioadmin
STORAGE_SECRET_KEY=minioadmin
STORAGE_BUCKET=delivery-app
STORAGE_PUBLIC_URL=http://localhost:9000

# OTP provider (WhatsApp-based)
OTP_API_BASE_URL=https://your-otp-provider.example.com
OTP_API_KEY=your-otp-api-key
